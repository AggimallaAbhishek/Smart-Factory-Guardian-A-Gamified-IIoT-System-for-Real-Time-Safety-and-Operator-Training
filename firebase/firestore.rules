rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isRoomHost(roomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId))
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostUid == request.auth.uid;
    }

    function isRoomParticipant(roomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
    }

    match /users/{uid} {
      allow read, write: if isSelf(uid);
    }

    match /rooms/{roomId} {
      allow read: if isRoomHost(roomId) || isRoomParticipant(roomId);

      allow create: if signedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == "lobby";

      // Room lifecycle updates are host-controlled. Participants can only perform
      // queue/connection metadata updates without changing gameplay control fields.
      allow update: if isRoomHost(roomId) || (
        isRoomParticipant(roomId)
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.status == resource.data.status
        && request.resource.data.turnDurationSec == resource.data.turnDurationSec
        && request.resource.data.activePlayerUid == resource.data.activePlayerUid
        && request.resource.data.turnStartedAtMs == resource.data.turnStartedAtMs
        && request.resource.data.turnEndsAtMs == resource.data.turnEndsAtMs
        && request.resource.data.turnNumber == resource.data.turnNumber
        && request.resource.data.activeAlert == resource.data.activeAlert
        && request.resource.data.createdAtMs == resource.data.createdAtMs
        && request.resource.data.endedAtMs == resource.data.endedAtMs
      );
      allow delete: if false;
    }

    match /rooms/{roomId}/players/{uid} {
      allow read: if isRoomHost(roomId) || isRoomParticipant(roomId);

      // Player records can be created/updated by host or the player itself.
      allow create, update: if isRoomHost(roomId) || isSelf(uid);
      allow delete: if false;
    }

    match /rooms/{roomId}/events/{eventId} {
      allow read: if isRoomHost(roomId) || isRoomParticipant(roomId);

      // Events are append-only and immutable for auditability.
      allow create: if isRoomHost(roomId) || isRoomParticipant(roomId);
      allow update, delete: if false;
    }
  }
}
